{
  "速读谷": {
    "sourceName": "速读谷",
    "sourceUrl": "https:\/\/www.sudugu.org",
    "sourceType": "text",
    "weight": "100",
    "enable": 1,
    "searchBook": {
      "actionID": "searchBook",
      "validConfig": "",
      "requestInfo": "https:\/\/www.sudugu.org\/i\/sor.aspx?key=%@keyWord&p=%@pageIndex",
      "parserID": "DOM",
      "responseFormatType": "html",
      "host": "https:\/\/www.sudugu.org",
      "list": "\/\/*[contains(@class,'item')]",
      "bookName": "\/\/h3\/\/a",
      "author": "\/\/*[contains(text(),'作者')]",
      "cat": "\/\/span",
      "lastChapterTitle": "\/\/li[1]\/\/a",
      "detailUrl": "\/\/h3\/a\/@href",
      "cover": "\/\/img\/@src"
    },
    "bookDetail": {
      "actionID": "bookDetail",
      "validConfig": "",
      "parserID": "DOM",
      "responseFormatType": "html",
      "host": "https:\/\/www.sudugu.org",
      "cover": "\/\/*[contains(@class,'item')]\/\/img\/@src",
      "desc": "\/\/*[contains(@class,'des')][1]",
      "detailUrl": "@js: return params.requestInfo;"
    },
    "chapterList": {
      "actionID": "chapterList",
      "validConfig": "",
      "parserID": "DOM",
      "responseFormatType": "html",
      "host": "https:\/\/www.sudugu.org",
      "//列表": "对应阅读的 .dir@li",
      "list": "\/\/*[contains(@class,'dir')]\/\/li",
      "title": "\/\/a",
      "url": "\/\/a\/@href",
      "//目录翻页": "对应阅读的 .gr@href",
      "nextPageUrl": "\/\/*[contains(@class,'gr')]\/@href",
      "//翻页开关": "必须加上才能抓取完整目录",
      "moreKeys": {
        "maxPage": 200
      }
    },
    "chapterContent": {
      "actionID": "chapterContent",
      "validConfig": "",
      "parserID": "DOM",
      "responseFormatType": "html",
      "host": "https:\/\/www.sudugu.org",
      "content": "\/\/*[contains(@class,'con')]",
      "nextPageUrl": "\/\/a[text()='下一页']\/@href"
    },
    "bookWorld": {
      "分类发现": {
        "actionID": "bookWorld",
        "validConfig": "",
        "parserID": "DOM",
        "responseFormatType": "html",
        "host": "https:\/\/www.sudugu.org",
        "requestInfo": "@js:\nreturn config.host + '\/' + params.filters.cat.replace('{{page}}', params.pageIndex);",
        "list": "\/\/*[contains(@class,'item')]",
        "bookName": "\/\/h3\/\/a",
        "author": "\/\/*[contains(text(),'作者')]",
        "lastChapterTitle": "\/\/ul\/li[1]\/\/a",
        "detailUrl": "\/\/h3\/a\/@href",
        "cover": "\/\/img\/@src",
        "moreKeys": {
          "pageSize": 20,
          "requestFilters": "cat\n 排行榜::paihang\/{{page}}.html\n 完结小说::wanjie\/{{page}}.html\n 最新小说::zuixin\/{{page}}.html\n 玄幻小说::xuanhuan\/{{page}}.html\n  仙侠小说::xianxia\/{{page}}.html\n 都市小说::dushi\/{{page}}.html\n 历史小说::lishi\/{{page}}.html\n 军事小说::junshi\/{{page}}.html\n 科幻小说::kehuan\/{{page}}.html\n 言情小说::yanqing\/{{page}}.html\n 庆小说::qing\/{{page}}.html\n 游戏小说::youxi\/{{page}}.html\n 奇幻小说::qihuan\/{{page}}.html\n 武侠小说::wuxia\/{{page}}.html\n "
        }
      }
    }
  }
}
