{
  "ꂵ 30读书": {
    "sourceName": "ꂵ 30读书",
    "sourceUrl": "https:\/\/www.30dushu.com",
    "sourceType": "text",
    "weight": "9999",
    "enable": 1,
    "searchBook": {
      "actionID": "searchBook",
      "validConfig": "",
      "requestInfo": "https:\/\/www.30dushu.com\/search\/?searchkey=%@keyWord",
      "parserID": "DOM",
      "responseFormatType": "html",
      "host": "https:\/\/www.30dushu.com",
      "list": "\/\/*[contains(@class,'modern-search-item')]",
      "bookName": "\/\/h3",
      "author": "\/\/a[contains(@href,'author')]",
      "cover": "\/\/img\/@src || @js:\nif(result.startsWith('http')) return result;\nreturn config.host + (result.startsWith('\/') ? '' : '\/') + result;",
      "desc": "\/\/*[contains(@class,'modern-book-desc')]",
      "cat": "\/\/*[contains(@class,'modern-book-meta')]\/\/span[1]",
      "detailUrl": "\/\/h3\/a\/@href || @js:\nif(result.startsWith('http')) return result;\nreturn config.host + (result.startsWith('\/') ? '' : '\/') + result;"
    },
    "bookDetail": {
      "actionID": "bookDetail",
      "validConfig": "",
      "parserID": "DOM",
      "responseFormatType": "html",
      "host": "https:\/\/www.30dushu.com",
      "cover": "\/\/img\/@data-original || @js:\nif(result.startsWith('http')) return result;\nreturn config.host + (result.startsWith('\/') ? '' : '\/') + result;",
      "desc": "\/\/*[contains(@class,'detail-intro-content')]",
      "cat": "\/\/*[contains(@class,'detail-book-tags')]\/\/span",
      "author": "\/\/a[contains(@href,'author')]",
      "lastChapterTitle": "\/\/*[contains(@class,'detail-chapter-title')][1]"
    },
    "chapterList": {
      "actionID": "chapterList",
      "validConfig": "",
      "requestInfo": "@js:\nreturn result.replace('\/book\/', '\/index\/');",
      "parserID": "DOM",
      "responseFormatType": "html",
      "host": "https:\/\/www.30dushu.com",
      "list": "\/\/*[contains(@class,'modern-chapter-item')]",
      "title": "\/\/@data-name",
      "url": "\/\/a\/@href",
      "nextPageUrl": "\/\/a[contains(text(),'下一页')]\/@href",
      "moreKeys": {
        "maxPage": 50
      }
    },
    "chapterContent": {
      "actionID": "chapterContent",
      "validConfig": "",
      "parserID": "DOM",
      "responseFormatType": "html",
      "host": "https:\/\/www.30dushu.com",
      "content": "\/\/*[@id='chapterContent']\/\/p"
    },
"bookWorld": {
      "常规分类": {
        "actionID": "bookWorld",
        "validConfig": "",
        "parserID": "DOM",
        "responseFormatType": "html",
        "host": "https:\/\/www.30dushu.com",
        "requestInfo": "@js:\nreturn config.host + '\/cate\/' + params.filters.cat + '-' + params.pageIndex + '.html';",
        "list": "\/\/div[@class='book-card']",
        "bookName": "\/\/h3",
        "author": "\/\/p",
        "cover": "\/\/img\/@src",
        "detailUrl": "\/\/a[contains(@class,'book-link')]\/@href",
        "moreKeys": {
          "pageSize": 30,
          "requestFilters": "cat\n 全部分类::0\n 玄幻魔法::1\n 武侠修真::2\n 都市言情::3\n 历史军事::4\n 游戏竞技::5\n 科幻灵异::6\n 纯爱同人::7\n 女生言情::8\n 二次元::9"
        }
      },
      "热门榜单": {
        "actionID": "bookWorld",
        "validConfig": "",
        "parserID": "DOM",
        "responseFormatType": "html",
        "host": "https:\/\/www.30dushu.com",
        "requestInfo": "@js:\nlet p = params.pageIndex - 1;\nreturn config.host + '\/rank-' + params.filters.rank + '-' + p + '.html';",
        "list": "\/\/div[@class='rank-item']",
        "bookName": "\/\/h3",
        "author": "\/\/div[@class='book-meta']\/span[1]\/text()[last()]",
        "cover": "\/\/img[@class='cover-img']\/@src",
        "kind": "\/\/div[@class='book-meta']\/span[2]\/text()[last()]",
        "detailUrl": "\/\/a[contains(@class,'book-link')]\/@href",
        "moreKeys": {
          "pageSize": 30,
          "requestFilters": "rank\n 总点击榜::allvisit\n 月点击榜::monthvisit\n 周点击榜::weekvisit\n 日点击榜::dayvisit\n 收藏榜::goodnum"
        }
      }
    }
  }
}